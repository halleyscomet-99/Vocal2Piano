# ======================================================================
# KiCad Project Files
# ======================================================================

# Temporary and local files generated by KiCad
*.bak
*.kicad_pcb-bak
*.kicad_sch-bak
*.fp-info-cache
*.lck

# Python scripting temporary files
__pycache__/
*.py[cod]

# ERC/DRC report files (Keep them only if you want a history of errors)
*.rpt

# Fabrication output log files
fp-lib-table.old
sym-lib-table.old

# ======================================================================
# Operating System Junk
# ======================================================================

# macOS specific files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows specific files
Thumbs.db
ehthumbs.db
Desktop.ini

# ======================================================================
# IDE and Editor Files
# ======================================================================

# VS Code
.vscode/
*.code-workspace

# Common text editors
*~
*.swp
*.swo

# ======================================================================
# Python
# ======================================================================

# Virtual environment
.venv/
venv/
env/

# Byte-compiled / optimized / DLL files (already have *.py[cod] above)
*.pyo

# Distribution / packaging
dist/
build/
*.egg-info/

# ======================================================================
# Node / Frontend
# ======================================================================

software/app/node_modules/

# ======================================================================
# PlatformIO
# ======================================================================

firmware/.pio/

# ======================================================================
# Audio / MIDI project files
# ======================================================================

software/files/input/
software/files/output/

# Learned Markov weights (generated, not source)
learned_transitions.json