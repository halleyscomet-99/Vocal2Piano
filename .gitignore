# ======================================================================
# KiCad Project Files
# ======================================================================

# Temporary and local files generated by KiCad
*.bak
*.kicad_pcb-bak
*.kicad_sch-bak
*.fp-info-cache
*.lck

# Python scripting temporary files
__pycache__/
*.py[cod]

# ERC/DRC report files (Keep them only if you want a history of errors)
*.rpt

# Fabrication output log files
fp-lib-table.old
sym-lib-table.old

# ======================================================================
# Operating System Junk
# ======================================================================

# macOS specific files
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Windows specific files
Thumbs.db
ehthumbs.db
Desktop.ini

# ======================================================================
# IDE and Editor Files
# ======================================================================

# VS Code
.vscode/
*.code-workspace

# Common text editors
*~
*.swp
*.swo