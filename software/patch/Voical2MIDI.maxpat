			{ "box" : { "id":"obj-sel0", "maxclass":"newobj",
				"numinlets":1, "numoutlets":2, "outlettype":["bang",""],
				"patching_rect":[ 230.0, 420.0, 55.0, 25.0 ],
				"text":"sel 0",
				"hint":"bangs when velocity = 0 (note off), triggers message 0 to clear kslider" } },
