				"text":"notein",
				"hint":"STEP 1: double-click here, select Voice2Piano_Layer1 from the list" } },

			{ "box" : { "id":"lbl-notein", "maxclass":"comment", "numinlets":1, "numoutlets":0,
				"patching_rect":[ 300.0, 72.0, 500.0, 18.0 ],
				"text":"<-- receives note pitch (outlet 0), velocity (outlet 1), channel (outlet 2)" } },

			{ "box" : { "id":"lbl-kb", "maxclass":"comment", "numinlets":1, "numoutlets":0,
				"patching_rect":[ 30.0, 104.0, 500.0, 18.0 ],
				"text":"KEYBOARD  -- the detected note lights up in real time. note off = key goes dark.",
				"fontface":1 } },

			{ "box" : { "id":"obj-kslider", "maxclass":"kslider",
				"numinlets":2, "numoutlets":2, "outlettype":["int","int"],
				"patching_rect":[ 30.0, 124.0, 760.0, 60.0 ],
				"hint":"inlet 0 = note number (lights up key)  inlet 1 = velocity (0 = note off = dark)" } },

			{ "box" : { "id":"lbl-hist", "maxclass":"comment", "numinlets":1, "numoutlets":0,
				"patching_rect":[ 30.0, 196.0, 760.0, 18.0 ],
				"text":"NOTE HISTORY  -- each bar is one detected note. bar height = pitch (C2 at bottom, C7 at top). scrolls left as new notes arrive.",
				"fontface":1 } },

			{ "box" : { "id":"obj-multislider", "maxclass":"multislider",
				"numinlets":1, "numoutlets":2, "outlettype":["","int"],
				"patching_rect":[ 30.0, 216.0, 760.0, 120.0 ],
				"size":80, "min":36, "max":96, "style":"bar",
				"hint":"receives  prepend append <note>  messages. each append adds a bar on the right and shifts older bars left." } },

			{ "box" : { "id":"obj-prepend", "maxclass":"newobj",
				"numinlets":1, "numoutlets":1, "outlettype":[""],
				"patching_rect":[ 30.0, 358.0, 120.0, 25.0 ],
				"text":"prepend append",
				"hint":"wraps the note number in an 'append' message so multislider adds it as a new rightmost bar" } },

			{ "box" : { "id":"obj-noteongate", "maxclass":"newobj",
				"numinlets":1, "numoutlets":2, "outlettype":["bang","int"],
				"patching_rect":[ 220.0, 358.0, 55.0, 25.0 ],
				"text":"sel 0",
				"hint":"sel 0: bangs when velocity = 0 (note off). used to close the gate so note-offs are not drawn as bars in the history" } },

			{ "box" : { "id":"obj-gate", "maxclass":"newobj",
				"numinlets":2, "numoutlets":2, "outlettype":["int","int"],
				"patching_rect":[ 30.0, 328.0, 65.0, 25.0 ],
				"text":"gate 1",
				"hint":"gate: only passes the note number to prepend when the gate is open (= note on, velocity > 0). closes when note off arrives." } },

			{ "box" : { "id":"lbl-info", "maxclass":"comment", "numinlets":1, "numoutlets":0,
